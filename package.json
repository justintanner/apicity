{
  "name": "apicity",
  "version": "1.0.0",
  "description": "Standalone AI provider packages - @apicity/kimicoding, @apicity/kie, @apicity/xai, @apicity/openai, @apicity/fal, @apicity/anthropic, @apicity/fireworks, @apicity/alibaba, @apicity/elevenlabs, and @apicity/free",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.12.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.30.3",
  "workspaces": [
    "packages/*/*",
    "examples/*"
  ],
  "scripts": {
    "build": "pnpm run build:kimicoding && pnpm run build:kie && pnpm run build:xai && pnpm run build:openai && pnpm run build:fal && pnpm run build:fireworks && pnpm run build:anthropic && pnpm run build:alibaba && pnpm run build:elevenlabs && pnpm run build:x && pnpm run build:ig && pnpm run build:free && pnpm run build:cost && pnpm run doc-gen",
    "build:openai": "pnpm --filter @apicity/openai run build",
    "build:kimicoding": "pnpm --filter @apicity/kimicoding run build",
    "build:kie": "pnpm --filter @apicity/kie run build",
    "build:xai": "pnpm --filter @apicity/xai run build",
    "build:fal": "pnpm --filter @apicity/fal run build",
    "build:fireworks": "pnpm --filter @apicity/fireworks run build",
    "build:anthropic": "pnpm --filter @apicity/anthropic run build",
    "build:alibaba": "pnpm --filter @apicity/alibaba run build",
    "build:elevenlabs": "pnpm --filter @apicity/elevenlabs run build",
    "build:x": "pnpm --filter @apicity/x run build",
    "build:ig": "pnpm --filter @apicity/ig run build",
    "build:free": "pnpm --filter @apicity/free run build",
    "build:cost": "pnpm --filter @apicity/cost run build",
    "doc-gen": "node scripts/doc-gen.mjs",
    "doc-gen:openai": "node scripts/doc-gen.mjs openai",
    "doc-gen:xai": "node scripts/doc-gen.mjs xai",
    "doc-gen:anthropic": "node scripts/doc-gen.mjs anthropic",
    "doc-gen:fireworks": "node scripts/doc-gen.mjs fireworks",
    "doc-gen:fal": "node scripts/doc-gen.mjs fal",
    "doc-gen:kimicoding": "node scripts/doc-gen.mjs kimicoding",
    "doc-gen:alibaba": "node scripts/doc-gen.mjs alibaba",
    "doc-gen:elevenlabs": "node scripts/doc-gen.mjs elevenlabs",
    "doc-gen:kie": "node scripts/doc-gen.mjs kie",
    "doc-gen:free": "node scripts/doc-gen.mjs free",
    "clean": "rm -rf packages/provider/*/dist",
    "prelint": "pnpm run build",
    "lint": "eslint . && node scripts/check-endpoint-comments.mjs && node scripts/check-endpoint-signatures.mjs",
    "lint:fix": "eslint . --fix",
    "lint:endpoints": "node scripts/check-endpoint-comments.mjs",
    "lint:signatures": "node scripts/check-endpoint-signatures.mjs",
    "lint:signatures:fix": "node scripts/apply-sigok-comments.mjs",
    "endpoint-map": "node scripts/endpoint-map.mjs",
    "endpoint-comments:apply": "node scripts/apply-endpoint-comments.mjs",
    "format": "prettier --write .",
    "test": "vitest --config tests/vitest.integration.ts",
    "test:run": "vitest run --config tests/vitest.integration.ts",
    "test:ui": "vitest --ui --config tests/vitest.integration.ts",
    "test:integration": "vitest run --config tests/vitest.integration.ts",
    "test:integration:record-missing": "op run --env-file=.env.tpl -- env POLLY_MODE=record-missing pnpm vitest run --config tests/vitest.integration.ts",
    "test:integration:record": "node tests/check-record-args.mjs",
    "test:coverage": "vitest run --config tests/vitest.integration.ts --coverage",
    "harness": "npx tsx tests/harness-serve.ts tests/recordings/",
    "harness:compare": "npx tsx tests/harness-serve.ts --compare tests/recordings/",
    "harness:report": "npx tsx tests/harness-report.ts",
    "harness:screenshot": "mkdir -p tests/fixtures/harness-generated && npx tsx tests/harness-serve.ts --html tests/fixtures/harness-generated/harness-report.html tests/recordings/ && npx tsx tests/harness-screenshot.ts tests/fixtures/harness-generated/harness-report.html tests/fixtures/harness-generated/harness-report.png",
    "harness:screenshot:media": "mkdir -p tests/fixtures/harness-generated && npx tsx tests/harness-serve.ts --html tests/fixtures/harness-generated/harness-report-media.html --media-only tests/recordings/ && npx tsx tests/harness-screenshot.ts tests/fixtures/harness-generated/harness-report-media.html tests/fixtures/harness-generated/harness-report-media.png",
    "dev:record": "pnpm run test:integration:record-missing",
    "dev:rerecord": "pnpm run test:integration:record",
    "dev:preflight": "pnpm run format && pnpm run lint && pnpm run test:run",
    "ci:local": "pnpm run build && pnpm run lint && pnpm run test:run",
    "check:op": "op run --env-file=.env.tpl -- node -e 'console.log(\"1Password OK — %d secrets resolved\", Object.keys(process.env).filter(k => [\"OPENAI_API_KEY\",\"KIE_API_KEY\",\"XAI_API_KEY\",\"KIMI_CODING_API_KEY\",\"FAL_API_KEY\",\"FIREWORKS_API_KEY\",\"ANTHROPIC_API_KEY\",\"DASHSCOPE_API_KEY\",\"ELEVENLABS_API_KEY\"].includes(k) && process.env[k] && !process.env[k].startsWith(\"op://\")).length)'",
    "compare:video": "pnpm run build:cost --silent && node scripts/compare-video-cost.mjs",
    "compare:image": "pnpm run build:cost --silent && node scripts/compare-image-cost.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@pollyjs/adapter-fetch": "^6.0.6",
    "@pollyjs/core": "^6.0.6",
    "@pollyjs/persister-fs": "^6.0.6",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "globals": "^14.0.0",
    "playwright": "^1.59.1",
    "prettier": "^3.0.0",
    "ts-morph": "^28.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.2.4",
    "zod": "^3.24.0"
  },
  "overrides": {
    "glob": "13.0.6",
    "vite": "6.4.2"
  },
  "pnpm": {
    "overrides": {
      "minimatch@<10.2.3": "10.2.3",
      "rollup@<4.59.0": "4.59.0",
      "esbuild@<=0.24.2": "0.25.0",
      "flatted@<3.4.2": "3.4.2",
      "picomatch@<4.0.4": "4.0.4",
      "brace-expansion@<5.0.5": "5.0.5",
      "path-to-regexp@<0.1.13": "0.1.13",
      "lodash-es@<=4.17.23": "4.18.0",
      "glob@<=10.5.0": "13.0.6",
      "vite@<6.4.2": "6.4.2",
      "postcss@<8.5.10": "8.5.10"
    }
  },
  "keywords": [
    "ai",
    "kimicoding",
    "kimi",
    "k2p5",
    "anthropic",
    "chat",
    "streaming",
    "embeddings",
    "openai",
    "fal",
    "fal-ai",
    "alibaba",
    "dashscope",
    "qwen",
    "elevenlabs",
    "sound-effects",
    "tmpfiles",
    "typescript"
  ],
  "author": "Justin Tanner",
  "license": "MIT",
  "repository": "github:justintanner/apicity"
}
