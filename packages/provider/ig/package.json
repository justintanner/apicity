{
  "name": "@apicity/ig",
  "version": "0.1.0",
  "description": "Instagram Graph API provider for posting reels via the public-URL flow (graph.instagram.com).",
  "license": "MIT",
  "repository": "github:justintanner/apicity",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./zod": {
      "import": "./dist/src/zod.js",
      "types": "./dist/src/zod.d.ts"
    }
  },
  "peerDependencies": {
    "zod": "^3.24.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "keywords": [
    "instagram",
    "ig",
    "meta",
    "social",
    "reels",
    "post",
    "media-publish",
    "apicity"
  ],
  "author": "Justin Tanner",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/dist.mjs",
    "prepublishOnly": "pnpm run build"
  }
}
