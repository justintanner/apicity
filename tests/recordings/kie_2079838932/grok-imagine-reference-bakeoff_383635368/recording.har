          "postData": {
            "mimeType": "application/json",
            "params": [],
            "text": "{\"model\":\"grok-imagine/image-to-video\",\"input\":{\"prompt\":\"@Image1 and @Image2 show the same white cat with mismatched yellow and blue eyes.\\n@Image3 is a man wearing a blue suit and blue tie.\\n@Image4 is a sandy beach with the ocean behind it.\\n\\nIn the scene, @Image3 sits cross-legged on the sand in the setting from @Image4. @Image1 climbs onto @Image3's lap, purrs, and lifts a paw to bat playfully at his blue tie. @Image3 smiles and waves at the camera with his free hand.\",\"image_urls\":[\"https://tempfile.redpandaai.co/kieai/136592/images/test-uploads/1777537997430-q2ajamt8uda.jpg\",\"https://tempfile.redpandaai.co/kieai/136592/images/test-uploads/1777537998016-5321n6oor.jpg\",\"https://tempfile.redpandaai.co/kieai/136592/images/test-uploads/1777537998573-4816p3iqdj7.jpg\",\"https://tempfile.redpandaai.co/kieai/136592/images/test-uploads/1777537999286-r7plxfbs2ui.png\"],\"duration\":\"6\",\"resolution\":\"480p\",\"aspect_ratio\":\"16:9\",\"mode\":\"fun\",\"nsfw_checker\":false}}"
